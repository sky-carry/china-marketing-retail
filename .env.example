# 复制为 .env 并填入真实值（.env 不入 git）
# 数据库（默认本地 PG，可省略）
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=inventory_check

# 看板登录
DASH_USER=admin
DASH_PASSWORD=change-me

# 伯俊 ERP 标准接口
BOJUN_BASE_URL=
BOJUN_APPKEY=
BOJUN_SECRET=

# 飞书网页登录（OAuth）；回调地址 http(s)://<host>/feishu/callback 需加入飞书后台重定向URL白名单
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 本地开发免登录：设为 1 时任何请求都视为已登录（生产切勿开启）
DEV_NO_AUTH=
